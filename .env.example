# Example environment variables for local development
# Copy this file to .env.local and fill in your values

# TTS API endpoint (Cloudflare Worker)
# After deploying workers/tts-api, set this to your worker URL
# Example: https://le-tts-api.your-subdomain.workers.dev/tts
# If not set, defaults to https://tts.le-portuguese.pages.dev/tts
VITE_TTS_API_URL=
